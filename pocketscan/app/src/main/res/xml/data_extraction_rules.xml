<?xml version="1.0" encoding="utf-8"?>
<!--
  Privacy-preserving by design: opt out of cloud/device-to-device transfer of all data.
  Scans are user-private and stay only on this device.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="root" />
        <exclude domain="file" />
        <exclude domain="database" />
        <exclude domain="sharedpref" />
    </device-transfer>
</data-extraction-rules>
